<% content_for(:title, @article.title) %>
<% content_for(:meta_description, @article.excerpt) if @article.excerpt.present? %>

<article>
  <%# Featured Image Hero %>
  <% if @article.featured_image.attached? %>
    <div class="relative h-64 w-full overflow-hidden bg-gray-900 sm:h-80 md:h-96">
      <%= image_tag @article.featured_image, class: "h-full w-full object-cover opacity-90", alt: @article.title %>
      <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
    </div>
  <% end %>

  <%# Article Header %>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <header class="<%= @article.featured_image.attached? ? '-mt-20 relative' : 'pt-10' %> pb-8">
      <div class="flex flex-wrap items-center gap-3 text-sm">
        <% if @article.category.present? %>
          <%= link_to @article.category.name, category_path(@article.category),
                class: "rounded-full bg-primary-600 px-3 py-1 text-xs font-semibold text-white shadow-sm transition hover:bg-primary-700" %>
        <% end %>
        <time class="text-gray-500 <%= @article.featured_image.attached? ? 'text-gray-300' : '' %>" datetime="<%= @article.published_at&.iso8601 %>">
          <%= @article.published_at&.strftime("%B %d, %Y") %>
        </time>
        <span class="<%= @article.featured_image.attached? ? 'text-gray-400' : 'text-gray-400' %>">&middot;</span>
        <span class="<%= @article.featured_image.attached? ? 'text-gray-300' : 'text-gray-500' %>"><%= @article.reading_time %> <%= t('shared.min_read') %></span>
      </div>

      <h1 class="mt-4 font-serif text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl <%= @article.featured_image.attached? ? 'text-white' : 'text-gray-900' %>">
        <%= @article.title %>
      </h1>

      <% if @article.excerpt.present? %>
        <p class="mt-4 text-lg leading-relaxed <%= @article.featured_image.attached? ? 'text-gray-200' : 'text-gray-600' %>">
          <%= @article.excerpt %>
        </p>
      <% end %>

      <%# Author info %>
      <div class="mt-6 flex items-center gap-4 border-b border-gray-200 pb-6">
        <% if @article.author.present? %>
          <% if @article.author.avatar.attached? %>
            <%= image_tag @article.author.avatar, class: "h-12 w-12 rounded-full object-cover ring-2 ring-white", alt: @article.author.localized_full_name %>
          <% else %>
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-sm font-bold text-primary-700 ring-2 ring-white">
              <%= @article.author.localized_initials %>
            </div>
          <% end %>
          <div>
            <p class="text-sm font-semibold text-gray-900"><%= @article.author.localized_full_name %></p>
            <p class="text-sm text-gray-500">
              <%= t('articles.published') %> <%= time_ago_in_words(@article.published_at) %> <%= t('shared.ago') %>
              &middot; <%= t('shared.views', count: @article.views_count) %>
            </p>
          </div>
        <% end %>
      </div>
    </header>

    <%# Article Body (Action Text) %>
    <div class="prose prose-lg prose-gray mx-auto max-w-none prose-headings:font-serif prose-headings:tracking-tight prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
      <%= @article.body %>
    </div>

    <%# Tags %>
    <% if @article.tags.any? %>
      <div class="mt-10 border-t border-gray-200 pt-6">
        <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-500"><%= t('articles.tags') %></h3>
        <div class="flex flex-wrap gap-2">
          <% @article.tags.each do |tag| %>
            <%= link_to tag_path(tag), class: "inline-flex items-center rounded-full border border-gray-200 bg-gray-50 px-3.5 py-1.5 text-sm text-gray-700 transition hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700" do %>
              #<%= tag.name %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</article>

<%# Sidebar Ad (between article and related) %>
<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 mt-10">
  <%= render_ad(:sidebar) %>
</div>

<%# Related Articles %>
<% if @related_articles.any? %>
  <section class="mt-12 border-t border-gray-200 bg-gray-50 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold tracking-tight text-gray-900"><%= t('articles.related_articles') %></h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <% @related_articles.each do |article| %>
          <%= render "shared/article_card", article: article, size: :small %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# Comments Section %>
<section class="border-t border-gray-200 py-12" id="comments">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">
      <%= t('articles.comments') %>
      <% if @comments.any? %>
        <span class="ml-2 text-lg font-normal text-gray-500">(<%= @comments.size %>)</span>
      <% end %>
    </h2>

    <%# Comment Form %>
    <div class="mt-8" id="comment-form">
      <% if signed_in? %>
        <% if @article.comments_enabled? %>
          <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5">
            <h3 class="mb-4 text-sm font-semibold text-gray-900"><%= t('articles.leave_comment') %></h3>
            <%= render "articles/comments/form", article: @article, comment: @comment %>
          </div>
        <% else %>
          <div class="rounded-xl bg-gray-100 p-6 text-center">
            <p class="text-sm text-gray-500"><%= t('articles.comments_disabled') %></p>
          </div>
        <% end %>
      <% else %>
        <div class="rounded-xl bg-gray-100 p-8 text-center">
          <svg class="mx-auto h-8 w-8 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 0 1 1.037-.443 48.282 48.282 0 0 0 5.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
          </svg>
          <p class="mt-3 text-sm text-gray-600">
            <%= t('articles.sign_in_to_comment_html', link: link_to(t('nav.sign_in'), login_path, class: "font-semibold text-primary-600 hover:text-primary-700")) %>
          </p>
        </div>
      <% end %>
    </div>

    <%# Comments List %>
    <% if @comments.any? %>
      <div class="mt-8 space-y-6">
        <% @comments.each do |comment| %>
          <%= render "articles/comments/comment", comment: comment, article: @article %>
        <% end %>
      </div>
    <% elsif @article.comments_enabled? %>
      <div class="mt-8 rounded-xl border-2 border-dashed border-gray-200 p-10 text-center">
        <p class="text-sm text-gray-500"><%= t('articles.no_comments') %></p>
      </div>
    <% end %>
  </div>
</section>
