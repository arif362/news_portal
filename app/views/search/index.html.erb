<% content_for(:title, @query.present? ? "#{t('search.title')}: #{@query}" : t('search.title')) %>

<div class="bg-white border-b border-gray-200">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 lg:text-4xl"><%= t('search.title') %></h1>
    <p class="mt-2 text-base text-gray-600"><%= t('search.subtitle') %></p>

    <%# Search input %>
    <div class="mt-6">
      <%= form_with url: search_path, method: :get, class: "relative", data: { turbo: false } do |f| %>
        <div class="relative">
          <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <%= f.search_field :q, value: @query,
                placeholder: t('search.placeholder'),
                autofocus: true,
                class: "block w-full rounded-xl border border-gray-300 bg-gray-50 py-4 pl-12 pr-24 text-base text-gray-900 placeholder-gray-500 shadow-sm transition focus:border-primary-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-primary-500",
                autocomplete: "off" %>
          <%= f.submit t('search.button'),
                class: "absolute right-2 top-1/2 -translate-y-1/2 rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <% if @query.present? %>
    <%# Results count %>
    <div class="mb-8">
      <% if @articles.any? %>
        <p class="text-sm text-gray-600">
          <%= t('search.showing_results') %>
          <span class="font-semibold text-gray-900">"<%= @query %>"</span>
        </p>
      <% end %>
    </div>

    <% if @articles.any? %>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% @articles.each do |article| %>
          <%= render "shared/article_card", article: article, size: :medium %>
        <% end %>
      </div>

      <%= render "shared/pagination" %>
    <% else %>
      <div class="rounded-xl border-2 border-dashed border-gray-300 p-16 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <h3 class="mt-4 text-lg font-semibold text-gray-900"><%= t('search.no_results') %></h3>
        <p class="mt-2 text-sm text-gray-500">
          <%= t('search.no_results_message', query: @query) %>
          <br><%= t('search.no_results_hint') %>
        </p>
        <div class="mt-6">
          <%= link_to t('search.browse_all'), articles_path,
                class: "inline-flex items-center gap-2 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-primary-700" %>
        </div>
      </div>
    <% end %>
  <% else %>
    <%# Empty state: no query %>
    <div class="rounded-xl border-2 border-dashed border-gray-300 p-16 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      <h3 class="mt-4 text-lg font-semibold text-gray-900"><%= t('search.start_searching') %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= t('search.start_hint') %></p>
    </div>
  <% end %>
</div>
