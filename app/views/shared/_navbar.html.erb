<nav class="sticky top-0 z-50 border-b border-gray-200 bg-white shadow-sm" data-controller="navbar">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <%# Logo %>
      <div class="flex shrink-0 items-center">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <span class="text-2xl font-extrabold tracking-tight text-gray-900">
            <%= t('app_name') %>
          </span>
        <% end %>
      </div>

      <%# Desktop Category Navigation %>
      <div class="hidden items-center gap-1 lg:flex">
        <% Category.active.roots.ordered.limit(6).each do |category| %>
          <%= link_to category.name, category_path(category),
                class: "rounded-md px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-100 hover:text-primary-600" %>
        <% end %>
      </div>

      <%# Right side: Search + Auth + Locale %>
      <div class="hidden items-center gap-3 md:flex">
        <%# Search form %>
        <%= form_with url: search_path, method: :get, class: "relative", data: { turbo: false } do |f| %>
          <div class="relative">
            <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
            <%= f.search_field :q, placeholder: t('nav.search_placeholder'),
                  class: "w-48 rounded-full border border-gray-300 bg-gray-50 py-2 pl-10 pr-4 text-sm text-gray-900 placeholder-gray-500 transition focus:w-64 focus:border-primary-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-primary-500",
                  autocomplete: "off" %>
          </div>
        <% end %>

        <%# Locale switcher %>
        <div class="flex items-center gap-1 text-xs text-gray-500">
          <% if I18n.locale == :en %>
            <span class="font-semibold text-primary-600">EN</span>
          <% else %>
            <%= link_to "EN", url_for(locale: nil), class: "hover:text-primary-600" %>
          <% end %>
          <span>|</span>
          <% if I18n.locale == :bn %>
            <span class="font-semibold text-primary-600">বাং</span>
          <% else %>
            <%= link_to "বাং", url_for(locale: :bn), class: "hover:text-primary-600" %>
          <% end %>
        </div>

        <%# Auth buttons %>
        <% if signed_in? %>
          <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-700">
              <%= current_user.first_name %>
            </span>
            <% if current_user.staff? %>
              <%= link_to t('nav.admin'), admin_root_path,
                    class: "rounded-md bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-200" %>
            <% end %>
            <%= button_to t('nav.sign_out'), logout_path, method: :delete,
                  class: "rounded-md border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-50" %>
          </div>
        <% else %>
          <div class="flex items-center gap-2">
            <%= link_to t('nav.sign_in'), login_path,
                  class: "rounded-md px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-100" %>
            <%= link_to t('nav.register'), register_path,
                  class: "rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" %>
          </div>
        <% end %>
      </div>

      <%# Mobile hamburger button %>
      <div class="flex md:hidden">
        <button type="button"
                class="inline-flex items-center justify-center rounded-md p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary-500"
                data-action="click->navbar#toggle"
                aria-expanded="false">
          <span class="sr-only"><%= t('nav.open_main_menu') %></span>
          <%# Hamburger icon %>
          <svg class="h-6 w-6" data-navbar-target="openIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <%# Close icon (hidden by default) %>
          <svg class="hidden h-6 w-6" data-navbar-target="closeIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <%# Mobile menu (hidden by default) %>
  <div class="hidden md:hidden" data-navbar-target="mobileMenu">
    <div class="space-y-1 border-t border-gray-200 px-4 pb-4 pt-3">
      <%# Mobile search %>
      <%= form_with url: search_path, method: :get, class: "mb-3", data: { turbo: false } do |f| %>
        <div class="relative">
          <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <%= f.search_field :q, placeholder: t('nav.search_placeholder'),
                class: "w-full rounded-lg border border-gray-300 bg-gray-50 py-2 pl-10 pr-4 text-sm text-gray-900 placeholder-gray-500 focus:border-primary-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        </div>
      <% end %>

      <%# Mobile category links %>
      <% Category.active.roots.ordered.limit(6).each do |category| %>
        <%= link_to category.name, category_path(category),
              class: "block rounded-md px-3 py-2 text-base font-medium text-gray-700 hover:bg-gray-100 hover:text-primary-600" %>
      <% end %>

      <div class="my-3 border-t border-gray-200"></div>

      <%# Mobile locale switcher %>
      <div class="flex items-center gap-2 px-3 py-2 text-sm text-gray-500">
        <% if I18n.locale == :en %>
          <span class="font-semibold text-primary-600">EN</span>
        <% else %>
          <%= link_to "EN", url_for(locale: nil), class: "hover:text-primary-600" %>
        <% end %>
        <span>|</span>
        <% if I18n.locale == :bn %>
          <span class="font-semibold text-primary-600">বাং</span>
        <% else %>
          <%= link_to "বাং", url_for(locale: :bn), class: "hover:text-primary-600" %>
        <% end %>
      </div>

      <div class="my-3 border-t border-gray-200"></div>

      <%# Mobile auth links %>
      <% if signed_in? %>
        <div class="space-y-1">
          <p class="px-3 py-2 text-sm font-semibold text-gray-900"><%= current_user.localized_full_name %></p>
          <% if current_user.staff? %>
            <%= link_to t('nav.admin_dashboard'), admin_root_path,
                  class: "block rounded-md px-3 py-2 text-base font-medium text-gray-700 hover:bg-gray-100" %>
          <% end %>
          <%= button_to t('nav.sign_out'), logout_path, method: :delete,
                class: "block w-full rounded-md px-3 py-2 text-left text-base font-medium text-gray-700 hover:bg-gray-100" %>
        </div>
      <% else %>
        <div class="space-y-1">
          <%= link_to t('nav.sign_in'), login_path,
                class: "block rounded-md px-3 py-2 text-base font-medium text-gray-700 hover:bg-gray-100" %>
          <%= link_to t('nav.create_account'), register_path,
                class: "block rounded-md bg-primary-600 px-3 py-2 text-center text-base font-medium text-white hover:bg-primary-700" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
