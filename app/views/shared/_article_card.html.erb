<%# Reusable article card: accepts `article` and optional `size` (:large, :medium, :small) %>
<% size ||= :medium %>

<% if size == :large %>
  <%# LARGE card: full width, big image, prominent title %>
  <%= link_to article_path(article), class: "group block overflow-hidden rounded-xl bg-white shadow-md ring-1 ring-gray-900/5 transition hover:shadow-lg" do %>
    <div class="relative aspect-video overflow-hidden">
      <% if article.featured_image.attached? %>
        <%= image_tag article.featured_image, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105", alt: article.title %>
      <% else %>
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-primary-100 to-primary-200">
          <svg class="h-16 w-16 text-primary-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
          </svg>
        </div>
      <% end %>
      <% if article.category.present? %>
        <span class="absolute left-4 top-4 rounded-full bg-primary-600 px-3 py-1 text-xs font-semibold text-white shadow-sm">
          <%= article.category.name %>
        </span>
      <% end %>
    </div>
    <div class="p-6">
      <h2 class="font-serif text-2xl font-bold leading-tight text-gray-900 transition group-hover:text-primary-600 lg:text-3xl">
        <%= article.title %>
      </h2>
      <% if article.excerpt.present? %>
        <p class="mt-3 text-base leading-relaxed text-gray-600">
          <%= truncate(article.excerpt, length: 200) %>
        </p>
      <% end %>
      <div class="mt-4 flex items-center gap-3 text-sm text-gray-500">
        <% if article.author.present? %>
          <span class="font-medium text-gray-700"><%= article.author.localized_full_name %></span>
          <span>&middot;</span>
        <% end %>
        <time datetime="<%= article.published_at&.iso8601 %>">
          <%= time_ago_in_words(article.published_at) %> <%= t('shared.ago') %>
        </time>
        <span>&middot;</span>
        <span><%= article.reading_time %> <%= t('shared.min_read') %></span>
      </div>
    </div>
  <% end %>

<% elsif size == :small %>
  <%# SMALL card: compact horizontal layout %>
  <%= link_to article_path(article), class: "group flex gap-4 rounded-lg p-2 transition hover:bg-gray-50" do %>
    <div class="h-20 w-20 shrink-0 overflow-hidden rounded-lg">
      <% if article.featured_image.attached? %>
        <%= image_tag article.featured_image, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105", alt: article.title %>
      <% else %>
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
          <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
          </svg>
        </div>
      <% end %>
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="text-sm font-semibold leading-snug text-gray-900 transition group-hover:text-primary-600">
        <%= truncate(article.title, length: 70) %>
      </h3>
      <div class="mt-1 flex items-center gap-2 text-xs text-gray-500">
        <time datetime="<%= article.published_at&.iso8601 %>">
          <%= time_ago_in_words(article.published_at) %> <%= t('shared.ago') %>
        </time>
        <% if article.category.present? %>
          <span>&middot;</span>
          <span class="text-primary-600"><%= article.category.name %></span>
        <% end %>
      </div>
    </div>
  <% end %>

<% else %>
  <%# MEDIUM card: standard card layout (default) %>
  <%= link_to article_path(article), class: "group flex flex-col overflow-hidden rounded-xl bg-white shadow-md ring-1 ring-gray-900/5 transition hover:shadow-lg" do %>
    <div class="relative aspect-video overflow-hidden">
      <% if article.featured_image.attached? %>
        <%= image_tag article.featured_image, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105", alt: article.title %>
      <% else %>
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
          <svg class="h-10 w-10 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
          </svg>
        </div>
      <% end %>
      <% if article.category.present? %>
        <span class="absolute left-3 top-3 rounded-full bg-primary-600 px-2.5 py-0.5 text-xs font-semibold text-white shadow-sm">
          <%= article.category.name %>
        </span>
      <% end %>
    </div>
    <div class="flex flex-1 flex-col p-5">
      <h3 class="font-serif text-lg font-bold leading-snug text-gray-900 transition group-hover:text-primary-600">
        <%= truncate(article.title, length: 80) %>
      </h3>
      <% if article.excerpt.present? %>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">
          <%= truncate(article.excerpt, length: 120) %>
        </p>
      <% end %>
      <div class="mt-4 flex items-center justify-between border-t border-gray-100 pt-4 text-xs text-gray-500">
        <div class="flex items-center gap-2">
          <% if article.author.present? %>
            <div class="flex h-6 w-6 items-center justify-center rounded-full bg-primary-100 text-xs font-semibold text-primary-700">
              <%= article.author.localized_initials %>
            </div>
            <span class="font-medium text-gray-700"><%= article.author.localized_full_name %></span>
          <% end %>
        </div>
        <time datetime="<%= article.published_at&.iso8601 %>">
          <%= time_ago_in_words(article.published_at) %> <%= t('shared.ago') %>
        </time>
      </div>
    </div>
  <% end %>
<% end %>
