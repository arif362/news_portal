<%# In-feed ad card that blends with article cards %>
<div class="group relative overflow-hidden rounded-xl bg-white ring-1 ring-gray-900/5 transition hover:shadow-md">
  <% if ad.image? && ad.image.attached? %>
    <% link_attrs = { class: "block", target: "_blank", rel: "noopener noreferrer sponsored", data: { turbo: false } } %>
    <%= link_to ad_click_path(ad), **link_attrs do %>
      <div class="relative aspect-video overflow-hidden">
        <%= image_tag ad.image, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105", alt: ad.alt_text || ad.title %>
        <span class="absolute left-3 top-3 rounded-full bg-gray-800/70 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white backdrop-blur-sm">
          Sponsored
        </span>
      </div>
      <div class="p-5">
        <h3 class="font-serif text-lg font-bold leading-snug text-gray-900 transition group-hover:text-primary-600">
          <%= ad.title %>
        </h3>
        <% if ad.description.present? %>
          <p class="mt-2 text-sm leading-relaxed text-gray-600 line-clamp-2"><%= ad.description %></p>
        <% end %>
        <div class="mt-3 flex items-center text-xs text-gray-400">
          <svg class="h-3.5 w-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
          <span class="truncate"><%= URI.parse(ad.target_url).host rescue "Learn more" %></span>
        </div>
      </div>
    <% end %>
  <% elsif ad.html? && ad.embed_code.present? %>
    <div class="relative">
      <span class="absolute left-3 top-3 z-10 rounded-full bg-gray-800/70 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white backdrop-blur-sm">
        Sponsored
      </span>
      <div class="p-4">
        <%= raw ad.embed_code %>
      </div>
    </div>
  <% end %>
</div>
