<%# Full-width leaderboard banner ad %>
<div class="relative bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200" data-controller="ad-dismiss">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
    <div class="relative flex items-center justify-center">
      <%# Ad Label %>
      <span class="absolute left-0 top-0 rounded-br bg-gray-400/80 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-white z-10">Ad</span>

      <%# Ad Content %>
      <% if ad.image? && ad.image.attached? %>
        <% link_attrs = { class: "block w-full text-center", target: "_blank", rel: "noopener noreferrer sponsored", data: { turbo: false } } %>
        <%= link_to ad_click_path(ad), **link_attrs do %>
          <%= image_tag ad.image, class: "mx-auto max-h-24 w-auto object-contain #{ad.responsive? ? 'max-w-full' : ''}", alt: ad.alt_text || ad.title %>
        <% end %>
      <% elsif ad.html? && ad.embed_code.present? %>
        <div class="w-full text-center">
          <%= raw ad.embed_code %>
        </div>
      <% end %>

      <%# Close Button %>
      <button type="button" data-action="click->ad-dismiss#close"
        class="absolute right-0 top-0 rounded-bl bg-gray-400/80 p-1 text-white hover:bg-gray-500 transition-colors z-10">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
</div>
