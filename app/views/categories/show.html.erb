<% content_for(:title, @category.name) %>

<div class="bg-white border-b border-gray-200">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <%# Breadcrumbs %>
    <nav class="mb-4 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-gray-500">
        <li>
          <%= link_to "Home", root_path, class: "transition hover:text-primary-600" %>
        </li>
        <li>
          <svg class="h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </li>
        <li>
          <%= link_to "Categories", categories_path, class: "transition hover:text-primary-600" %>
        </li>
        <li>
          <svg class="h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </li>
        <% if @category.parent.present? %>
          <li>
            <%= link_to @category.parent.name, category_path(@category.parent), class: "transition hover:text-primary-600" %>
          </li>
          <li>
            <svg class="h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </li>
        <% end %>
        <li class="font-medium text-gray-900"><%= @category.name %></li>
      </ol>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-gray-900 lg:text-4xl"><%= @category.name %></h1>
    <% if @category.description.present? %>
      <p class="mt-2 max-w-2xl text-base text-gray-600"><%= @category.description %></p>
    <% end %>
  </div>
</div>

<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <%# Subcategories %>
  <% if @subcategories.any? %>
    <div class="mb-10">
      <h2 class="mb-4 text-lg font-semibold text-gray-900">Subcategories</h2>
      <div class="flex flex-wrap gap-3">
        <% @subcategories.each do |subcategory| %>
          <%= link_to category_path(subcategory), class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 shadow-sm transition hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700" do %>
            <svg class="h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
            </svg>
            <%= subcategory.name %>
            <span class="text-xs text-gray-400">(<%= subcategory.articles.published.count %>)</span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Articles grid %>
  <% if @articles.any? %>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @articles.each do |article| %>
        <%= render "shared/article_card", article: article, size: :medium %>
      <% end %>
    </div>

    <%= render "shared/pagination" %>
  <% else %>
    <div class="rounded-xl border-2 border-dashed border-gray-300 p-16 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5" />
      </svg>
      <h3 class="mt-4 text-lg font-semibold text-gray-900">No articles in this category</h3>
      <p class="mt-1 text-sm text-gray-500">Check back soon for new content in <%= @category.name %>.</p>
    </div>
  <% end %>
</div>
