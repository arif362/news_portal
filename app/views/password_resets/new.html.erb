<% content_for(:title, t('auth.password_reset.title')) %>

<h2 class="text-center text-2xl font-bold tracking-tight text-gray-900">
  <%= t('auth.password_reset.title') %>
</h2>
<p class="mt-2 text-center text-sm text-gray-600">
  <%= t('auth.password_reset.subtitle') %>
</p>

<%= form_with url: password_reset_path, class: "mt-8 space-y-5" do |f| %>
  <div>
    <%= f.label :email, t('auth.password_reset.email'), class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            required: true,
            placeholder: t('auth.password_reset.email_placeholder'),
            class: "block w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm transition focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
    </div>
  </div>

  <div>
    <%= f.submit t('auth.password_reset.submit'),
          class: "flex w-full justify-center rounded-lg bg-primary-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 cursor-pointer" %>
  </div>
<% end %>

<div class="mt-6 text-center">
  <p class="text-sm text-gray-600">
    <%= t('auth.password_reset.remember_password') %>
    <%= link_to t('auth.password_reset.back_to_sign_in'), login_path,
          class: "font-semibold text-primary-600 transition hover:text-primary-500" %>
  </p>
</div>
