<% content_for(:title, @article.title) %>

<div class="mb-6">
  <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
    <%= link_to "Articles", admin_articles_path, class: "hover:text-primary-600" %>
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-700"><%= truncate(@article.title, length: 50) %></span>
  </div>

  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <h1 class="text-2xl font-bold text-gray-900"><%= @article.title %></h1>
      <% case @article.status %>
      <% when "published" %>
        <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">Published</span>
      <% when "draft" %>
        <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800">Draft</span>
      <% when "archived" %>
        <span class="inline-flex items-center rounded-full bg-yellow-100 px-3 py-1 text-sm font-medium text-yellow-800">Archived</span>
      <% end %>
    </div>

    <div class="flex items-center space-x-3">
      <%= link_to edit_admin_article_path(@article), class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm border border-gray-300 hover:bg-gray-50 transition-colors" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit
      <% end %>

      <% if @article.draft? %>
        <%= button_to publish_admin_article_path(@article), method: :patch, class: "inline-flex items-center rounded-md bg-green-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-green-700 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Publish
        <% end %>
      <% end %>

      <% if @article.published? %>
        <%= button_to unpublish_admin_article_path(@article), method: :patch, class: "inline-flex items-center rounded-md bg-gray-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-700 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
          </svg>
          Unpublish
        <% end %>
      <% end %>

      <% unless @article.archived? %>
        <%= button_to archive_admin_article_path(@article), method: :patch, class: "inline-flex items-center rounded-md bg-yellow-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-yellow-700 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
          </svg>
          Archive
        <% end %>
      <% end %>

      <%= button_to admin_article_path(@article), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this article?" }, class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 transition-colors" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete
      <% end %>
    </div>
  </div>
</div>

<%# Article Details %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Main Content %>
  <div class="lg:col-span-2 space-y-6">
    <%# Featured Image %>
    <% if @article.featured_image.attached? %>
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <%= image_tag @article.featured_image, class: "w-full h-auto object-cover max-h-96" %>
      </div>
    <% end %>

    <%# Excerpt %>
    <% if @article.excerpt.present? %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-2">Excerpt</h3>
        <p class="text-gray-700 italic"><%= @article.excerpt %></p>
      </div>
    <% end %>

    <%# Body %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Body</h3>
      <div class="prose max-w-none">
        <%= @article.body %>
      </div>
    </div>
  </div>

  <%# Sidebar Details %>
  <div class="space-y-6">
    <%# Article Info %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Details</h3>
      <dl class="space-y-4">
        <div>
          <dt class="text-xs font-medium text-gray-500">Author</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @article.author.full_name %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Category</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @article.category.name %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Tags</dt>
          <dd class="mt-1 flex flex-wrap gap-1">
            <% if @article.tags.any? %>
              <% @article.tags.each do |tag| %>
                <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-800"><%= tag.name %></span>
              <% end %>
            <% else %>
              <span class="text-sm text-gray-400">No tags</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Views</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= number_with_delimiter(@article.views_count) %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Comments</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <%= @article.comments.count %>
            <% if @article.comments_enabled? %>
              <span class="text-green-600">(enabled)</span>
            <% else %>
              <span class="text-red-600">(disabled)</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <%# Flags %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Flags</h3>
      <div class="space-y-2">
        <div class="flex items-center">
          <% if @article.featured? %>
            <svg class="h-5 w-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <% else %>
            <svg class="h-5 w-5 text-gray-300 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          <% end %>
          <span class="text-sm text-gray-700">Featured</span>
        </div>
        <div class="flex items-center">
          <% if @article.breaking? %>
            <svg class="h-5 w-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <% else %>
            <svg class="h-5 w-5 text-gray-300 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          <% end %>
          <span class="text-sm text-gray-700">Breaking News</span>
        </div>
        <div class="flex items-center">
          <% if @article.comments_enabled? %>
            <svg class="h-5 w-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <% else %>
            <svg class="h-5 w-5 text-gray-300 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          <% end %>
          <span class="text-sm text-gray-700">Comments Enabled</span>
        </div>
      </div>
    </div>

    <%# Dates %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Dates</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-xs font-medium text-gray-500">Created</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @article.created_at.strftime("%b %d, %Y at %I:%M %p") %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Updated</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @article.updated_at.strftime("%b %d, %Y at %I:%M %p") %></dd>
        </div>
        <% if @article.published_at.present? %>
          <div>
            <dt class="text-xs font-medium text-gray-500">Published</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @article.published_at.strftime("%b %d, %Y at %I:%M %p") %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <%# SEO Info %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">SEO</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-xs font-medium text-gray-500">Meta Title</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @article.meta_title.presence || "---" %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Meta Description</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @article.meta_description.presence || "---" %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Meta Keywords</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @article.meta_keywords.presence || "---" %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
