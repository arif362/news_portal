<%= render "admin/shared/form_errors", resource: @user %>

<%= form_with(model: [:admin, @user], class: "space-y-6 max-w-2xl") do |f| %>
  <%# Personal Information %>
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Personal Information</h3>
    <div class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "First name" %>
        </div>
        <div>
          <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "Last name" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name_bn, "First Name (Bangla)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name_bn, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "নামের প্রথম অংশ" %>
        </div>
        <div>
          <%= f.label :last_name_bn, "Last Name (Bangla)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name_bn, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "নামের শেষ অংশ" %>
        </div>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "email@example.com" %>
      </div>

      <div>
        <%= f.label :username, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="flex rounded-md shadow-sm">
          <span class="inline-flex items-center rounded-l-md border border-r-0 border-gray-300 bg-gray-50 px-3 text-sm text-gray-500">@</span>
          <%= f.text_field :username, class: "block w-full rounded-none rounded-r-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "username" %>
        </div>
        <p class="mt-1 text-xs text-gray-500">Letters, numbers, and underscores only (3-30 characters).</p>
      </div>

      <div>
        <%= f.label :role, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :role, User.roles.keys.map { |r| [t("roles.#{r}"), r] }, {}, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :bio, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :bio, rows: 3, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none resize-none", placeholder: "Brief bio" %>
      </div>
    </div>
  </div>

  <%# Password %>
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">
      Password
      <% if @user.persisted? %>
        <span class="font-normal normal-case text-gray-400">(leave blank to keep current password)</span>
      <% end %>
    </h3>
    <div class="space-y-4">
      <div>
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "Minimum 8 characters", autocomplete: "new-password" %>
      </div>
      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "Confirm password", autocomplete: "new-password" %>
      </div>
    </div>
  </div>

  <%# Avatar %>
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Avatar</h3>
    <% if @user.persisted? && @user.avatar.attached? %>
      <div class="mb-4">
        <%= image_tag @user.avatar, class: "h-20 w-20 rounded-full object-cover" %>
      </div>
    <% end %>
    <%= f.file_field :avatar, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer" %>
    <p class="mt-1 text-xs text-gray-500">Accepted formats: JPG, PNG, GIF. Recommended size: 200x200px.</p>
  </div>

  <%# Submit %>
  <div class="flex items-center justify-end space-x-3">
    <%= link_to "Cancel", admin_users_path, class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm border border-gray-300 hover:bg-gray-50 transition-colors" %>
    <%= f.submit @user.persisted? ? "Update User" : "Create User", class: "inline-flex items-center rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700 transition-colors cursor-pointer" %>
  </div>
<% end %>
