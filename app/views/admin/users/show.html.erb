<% content_for(:title, @user.full_name) %>

<div class="mb-6">
  <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
    <%= link_to "Users", admin_users_path, class: "hover:text-primary-600" %>
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-700"><%= @user.full_name %></span>
  </div>

  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= @user.full_name %></h1>
    <div class="flex items-center space-x-3">
      <%= link_to edit_admin_user_path(@user), class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm border border-gray-300 hover:bg-gray-50 transition-colors" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit
      <% end %>

      <% if @user != current_user %>
        <%= button_to toggle_active_admin_user_path(@user), method: :patch, class: "inline-flex items-center rounded-md #{@user.active? ? 'bg-orange-600 hover:bg-orange-700' : 'bg-green-600 hover:bg-green-700'} px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors" do %>
          <%= @user.active? ? "Deactivate" : "Activate" %>
        <% end %>

        <%= button_to admin_user_path(@user), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this user?" }, class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 transition-colors" do %>
          Delete
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Profile Card %>
  <div class="bg-white rounded-lg shadow-sm p-6">
    <div class="text-center">
      <div class="mx-auto mb-4">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "h-24 w-24 rounded-full object-cover mx-auto" %>
        <% else %>
          <div class="h-24 w-24 rounded-full bg-gray-200 flex items-center justify-center mx-auto">
            <span class="text-2xl font-medium text-gray-500"><%= @user.first_name[0] %><%= @user.last_name[0] %></span>
          </div>
        <% end %>
      </div>
      <h3 class="text-lg font-semibold text-gray-900"><%= @user.full_name %></h3>
      <p class="text-sm text-gray-500">@<%= @user.username %></p>
      <div class="mt-2">
        <% case @user.role %>
        <% when "admin" %>
          <span class="inline-flex items-center rounded-full bg-purple-100 px-3 py-1 text-sm font-medium text-purple-800">Admin</span>
        <% when "editor" %>
          <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800">Editor</span>
        <% when "author" %>
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">Author</span>
        <% when "reader" %>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800">Reader</span>
        <% end %>

        <% if @user.active? %>
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800 ml-1">Active</span>
        <% else %>
          <span class="inline-flex items-center rounded-full bg-red-100 px-3 py-1 text-sm font-medium text-red-800 ml-1">Inactive</span>
        <% end %>
      </div>
    </div>

    <% if @user.bio.present? %>
      <div class="mt-4 pt-4 border-t border-gray-200">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Bio</h4>
        <p class="text-sm text-gray-700"><%= @user.bio %></p>
      </div>
    <% end %>
  </div>

  <%# User Details and Stats %>
  <div class="lg:col-span-2 space-y-6">
    <%# Contact & Account Info %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Account Information</h3>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <dt class="text-xs font-medium text-gray-500">Email</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.email %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Username</dt>
          <dd class="mt-1 text-sm text-gray-900">@<%= @user.username %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Joined</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.created_at.strftime("%b %d, %Y") %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Last Sign In</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_at&.strftime("%b %d, %Y at %I:%M %p") || "Never" %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Sign In Count</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.sign_in_count %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Last Sign In IP</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_ip || "---" %></dd>
        </div>
      </dl>
    </div>

    <%# Activity Stats %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Activity</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="text-center p-4 bg-gray-50 rounded-lg">
          <p class="text-2xl font-bold text-gray-900"><%= @user.articles.count %></p>
          <p class="text-sm text-gray-500">Articles</p>
        </div>
        <div class="text-center p-4 bg-gray-50 rounded-lg">
          <p class="text-2xl font-bold text-gray-900"><%= @user.comments.count %></p>
          <p class="text-sm text-gray-500">Comments</p>
        </div>
        <div class="text-center p-4 bg-gray-50 rounded-lg">
          <p class="text-2xl font-bold text-gray-900"><%= @user.articles.published.count %></p>
          <p class="text-sm text-gray-500">Published</p>
        </div>
      </div>
    </div>

    <%# Recent Articles %>
    <% if @user.articles.any? %>
      <div class="bg-white rounded-lg shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Recent Articles</h3>
        </div>
        <div class="divide-y divide-gray-200">
          <% @user.articles.order(created_at: :desc).limit(5).each do |article| %>
            <div class="px-6 py-3 flex items-center justify-between hover:bg-gray-50">
              <%= link_to truncate(article.title, length: 50), admin_article_path(article), class: "text-sm text-gray-900 hover:text-primary-600" %>
              <% case article.status %>
              <% when "published" %>
                <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-800">Published</span>
              <% when "draft" %>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-800">Draft</span>
              <% when "archived" %>
                <span class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-800">Archived</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
