<%# Admin Top Bar %>
<header class="bg-white shadow-sm sticky top-0 z-20">
  <div class="flex items-center justify-between px-6 py-4">
    <%# Left: Mobile sidebar toggle %>
    <div class="flex items-center">
      <button class="lg:hidden mr-4 text-gray-500 hover:text-gray-700 focus:outline-none"
              data-action="click->admin-sidebar#toggle"
              aria-label="Toggle sidebar">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <h2 class="text-lg font-semibold text-gray-800 lg:hidden">
        <%= content_for(:title) || "Dashboard" %>
      </h2>
    </div>

    <%# Right: User greeting and logout %>
    <div class="flex items-center space-x-4">
      <span class="text-sm text-gray-600">
        Hello, <span class="font-medium text-gray-800"><%= current_user.first_name %></span>
      </span>

      <%= button_to logout_path, method: :delete, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-md hover:bg-gray-50 hover:text-gray-800 transition-colors" do %>
        <svg class="h-4 w-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        Logout
      <% end %>
    </div>
  </div>
</header>
