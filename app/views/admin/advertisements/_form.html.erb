<%= render "admin/shared/form_errors", resource: @advertisement %>

<%= form_with(model: [:admin, @advertisement], class: "space-y-6") do |f| %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Main Content Column %>
    <div class="lg:col-span-2 space-y-6">
      <%# Title & Description with Language Tabs %>
      <div class="bg-white rounded-lg shadow-sm p-6" data-controller="locale-tabs">
        <%= render "admin/shared/locale_tabs" %>

        <%# English Panel %>
        <div data-locale-tabs-target="panel" data-locale="en" class="space-y-4">
          <div>
            <%= f.label :title_en, "Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :title_en, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "Enter advertisement title" %>
          </div>
          <div>
            <%= f.label :description_en, "Description", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :description_en, rows: 3, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none resize-none", placeholder: "Optional description or campaign notes" %>
          </div>
        </div>

        <%# Bangla Panel %>
        <div data-locale-tabs-target="panel" data-locale="bn" hidden class="space-y-4">
          <div>
            <%= f.label :title_bn, "Title (বাংলা)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :title_bn, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "বিজ্ঞাপনের শিরোনাম লিখুন" %>
          </div>
          <div>
            <%= f.label :description_bn, "Description (বাংলা)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :description_bn, rows: 3, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none resize-none", placeholder: "ঐচ্ছিক বিবরণ" %>
          </div>
        </div>
      </div>

      <%# Ad Content %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-700 mb-4">Ad Content</h3>

        <%# Ad Type Selector %>
        <div class="mb-4">
          <%= f.label :ad_type, "Ad Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="flex gap-4">
            <label class="flex items-center cursor-pointer">
              <%= f.radio_button :ad_type, "image", class: "text-primary-600 focus:ring-primary-500", data: { action: "change->ad-type-toggle#switch" } %>
              <span class="ml-2 text-sm text-gray-700">Image Banner</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <%= f.radio_button :ad_type, "html", class: "text-primary-600 focus:ring-primary-500", data: { action: "change->ad-type-toggle#switch" } %>
              <span class="ml-2 text-sm text-gray-700">HTML / Embed Code</span>
            </label>
          </div>
        </div>

        <%# Image Upload %>
        <div id="ad-image-fields" class="<%= 'hidden' if @advertisement.html? %>">
          <% if @advertisement.persisted? && @advertisement.image.attached? %>
            <div class="mb-4">
              <%= image_tag @advertisement.image, class: "rounded-lg max-h-48 object-cover" %>
            </div>
          <% end %>
          <%= f.file_field :image, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer" %>
          <p class="mt-1 text-xs text-gray-500">Accepted formats: JPG, PNG, GIF, WebP. Recommended: 728x90 (banner), 300x250 (sidebar).</p>

          <div class="mt-4">
            <%= f.label :target_url, "Click-through URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.url_field :target_url, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "https://example.com/landing-page" %>
          </div>

          <div class="mt-3">
            <%= f.label :alt_text, "Alt Text", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :alt_text, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "Descriptive text for accessibility" %>
          </div>
        </div>

        <%# HTML Embed %>
        <div id="ad-html-fields" class="<%= 'hidden' unless @advertisement.html? %>">
          <%= f.label :embed_code, "Embed Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :embed_code, rows: 8, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none font-mono", placeholder: "<script>...</script> or <div>...</div>" %>
          <p class="mt-1 text-xs text-gray-500">Paste your ad network code (Google Ads, etc.) or custom HTML.</p>
        </div>
      </div>
    </div>

    <%# Sidebar Column %>
    <div class="space-y-6">
      <%# Placement & Position %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-700 mb-4">Placement</h3>
        <div class="space-y-4">
          <div>
            <%= f.label :placement, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :placement, Advertisement.placements.keys.map { |p| [p.titleize, p] }, {}, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" %>
          </div>
          <div>
            <%= f.label :position, "Sort Position", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :position, min: 0, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none", placeholder: "0" %>
            <p class="mt-1 text-xs text-gray-500">Lower numbers display first.</p>
          </div>
        </div>
      </div>

      <%# Scheduling %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-700 mb-4">Schedule</h3>
        <div class="space-y-4">
          <div>
            <%= f.label :starts_at, "Start Date", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.datetime_local_field :starts_at, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" %>
          </div>
          <div>
            <%= f.label :ends_at, "End Date", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.datetime_local_field :ends_at, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" %>
          </div>
          <p class="text-xs text-gray-500">Leave blank for no scheduling restrictions.</p>
        </div>
      </div>

      <%# Status & Options %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-700 mb-4">Status & Options</h3>
        <div class="space-y-4">
          <div>
            <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :status, Advertisement.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" %>
          </div>
          <label class="flex items-center space-x-3 cursor-pointer">
            <%= f.check_box :open_in_new_tab, class: "rounded border-gray-300 text-primary-600 focus:ring-primary-500" %>
            <div>
              <span class="text-sm font-medium text-gray-700">Open in New Tab</span>
              <p class="text-xs text-gray-500">Open click-through URL in a new browser tab</p>
            </div>
          </label>
          <label class="flex items-center space-x-3 cursor-pointer">
            <%= f.check_box :responsive, class: "rounded border-gray-300 text-primary-600 focus:ring-primary-500" %>
            <div>
              <span class="text-sm font-medium text-gray-700">Responsive</span>
              <p class="text-xs text-gray-500">Adapt ad size to container width</p>
            </div>
          </label>
        </div>
      </div>

      <%# Submit %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="flex items-center justify-between space-x-3">
          <%= link_to "Cancel", admin_advertisements_path, class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm border border-gray-300 hover:bg-gray-50 transition-colors" %>
          <%= f.submit @advertisement.persisted? ? "Update Advertisement" : "Create Advertisement", class: "inline-flex items-center rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700 transition-colors cursor-pointer" %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
  // Simple ad type toggle (no Stimulus needed for this small interaction)
  document.addEventListener("DOMContentLoaded", function() {
    const radios = document.querySelectorAll('input[name="advertisement[ad_type]"]');
    const imageFields = document.getElementById("ad-image-fields");
    const htmlFields = document.getElementById("ad-html-fields");

    radios.forEach(function(radio) {
      radio.addEventListener("change", function() {
        if (this.value === "image") {
          imageFields.classList.remove("hidden");
          htmlFields.classList.add("hidden");
        } else {
          imageFields.classList.add("hidden");
          htmlFields.classList.remove("hidden");
        }
      });
    });
  });
</script>
