<% content_for(:title, @advertisement.title) %>

<div class="mb-6">
  <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
    <%= link_to "Advertisements", admin_advertisements_path, class: "hover:text-primary-600" %>
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-700"><%= truncate(@advertisement.title, length: 50) %></span>
  </div>

  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <h1 class="text-2xl font-bold text-gray-900"><%= @advertisement.title %></h1>
      <% case @advertisement.status %>
      <% when "active" %>
        <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">
          <span class="mr-1.5 h-2 w-2 rounded-full bg-green-500"></span>
          Active
        </span>
      <% when "draft" %>
        <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800">Draft</span>
      <% when "paused" %>
        <span class="inline-flex items-center rounded-full bg-yellow-100 px-3 py-1 text-sm font-medium text-yellow-800">Paused</span>
      <% when "expired" %>
        <span class="inline-flex items-center rounded-full bg-red-100 px-3 py-1 text-sm font-medium text-red-800">Expired</span>
      <% end %>
    </div>

    <div class="flex items-center space-x-3">
      <%= link_to edit_admin_advertisement_path(@advertisement), class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm border border-gray-300 hover:bg-gray-50 transition-colors" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit
      <% end %>

      <% if @advertisement.draft? || @advertisement.paused? %>
        <%= button_to activate_admin_advertisement_path(@advertisement), method: :patch, class: "inline-flex items-center rounded-md bg-green-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-green-700 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Activate
        <% end %>
      <% end %>

      <% if @advertisement.active? %>
        <%= button_to pause_admin_advertisement_path(@advertisement), method: :patch, class: "inline-flex items-center rounded-md bg-yellow-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-yellow-700 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Pause
        <% end %>
      <% end %>

      <%= button_to admin_advertisement_path(@advertisement), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this advertisement?" }, class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 transition-colors" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete
      <% end %>
    </div>
  </div>
</div>

<%# Analytics Cards %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%# Impressions %>
  <div class="bg-white rounded-lg shadow-sm p-5">
    <div class="flex items-center">
      <div class="rounded-lg bg-blue-100 p-2.5 mr-3">
        <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Impressions</p>
        <p class="text-xl font-bold text-gray-900"><%= number_with_delimiter(@advertisement.impressions_count) %></p>
      </div>
    </div>
  </div>

  <%# Clicks %>
  <div class="bg-white rounded-lg shadow-sm p-5">
    <div class="flex items-center">
      <div class="rounded-lg bg-green-100 p-2.5 mr-3">
        <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Clicks</p>
        <p class="text-xl font-bold text-gray-900"><%= number_with_delimiter(@advertisement.clicks_count) %></p>
      </div>
    </div>
  </div>

  <%# CTR %>
  <div class="bg-white rounded-lg shadow-sm p-5">
    <div class="flex items-center">
      <div class="rounded-lg bg-purple-100 p-2.5 mr-3">
        <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">CTR</p>
        <p class="text-xl font-bold <%= @advertisement.ctr > 2 ? 'text-green-600' : 'text-gray-900' %>"><%= @advertisement.ctr %>%</p>
      </div>
    </div>
  </div>

  <%# Days Remaining / Status %>
  <div class="bg-white rounded-lg shadow-sm p-5">
    <div class="flex items-center">
      <div class="rounded-lg bg-orange-100 p-2.5 mr-3">
        <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Remaining</p>
        <% days = @advertisement.days_remaining %>
        <% if days.present? %>
          <p class="text-xl font-bold <%= days <= 3 ? 'text-red-600' : 'text-gray-900' %>"><%= days %> <span class="text-sm font-normal text-gray-500">days</span></p>
        <% else %>
          <p class="text-xl font-bold text-gray-400">---</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Ad Details %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Main Content %>
  <div class="lg:col-span-2 space-y-6">
    <%# Ad Preview %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Preview</h3>
      <div class="rounded-lg border-2 border-dashed border-gray-200 p-4 bg-gray-50">
        <% if @advertisement.image? && @advertisement.image.attached? %>
          <div class="text-center">
            <%= image_tag @advertisement.image, class: "max-w-full h-auto rounded-lg mx-auto", alt: @advertisement.alt_text || @advertisement.title %>
          </div>
        <% elsif @advertisement.html? && @advertisement.embed_code.present? %>
          <div class="border border-gray-300 rounded-lg p-4 bg-white">
            <p class="text-xs text-gray-400 mb-2">HTML Embed Preview (code only):</p>
            <pre class="text-xs text-gray-600 overflow-x-auto whitespace-pre-wrap"><%= @advertisement.embed_code %></pre>
          </div>
        <% else %>
          <div class="text-center py-8 text-gray-400">
            <svg class="mx-auto h-12 w-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-sm">No ad content uploaded yet</p>
          </div>
        <% end %>
      </div>
    </div>

    <%# Description %>
    <% if @advertisement.description.present? %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-2">Description</h3>
        <p class="text-gray-700"><%= @advertisement.description %></p>
      </div>
    <% end %>

    <%# Campaign Timeline %>
    <% if @advertisement.scheduled? %>
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Campaign Timeline</h3>
        <div class="flex items-center gap-4">
          <div class="text-center">
            <p class="text-xs text-gray-500">Start</p>
            <p class="text-sm font-semibold text-gray-900"><%= @advertisement.starts_at&.strftime("%b %d, %Y") || "No start date" %></p>
            <p class="text-xs text-gray-400"><%= @advertisement.starts_at&.strftime("%I:%M %p") %></p>
          </div>
          <div class="flex-1 border-t-2 border-dashed border-gray-300 relative">
            <% if @advertisement.running? %>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-green-500 rounded-full h-3 w-3 ring-4 ring-green-100"></div>
            <% end %>
          </div>
          <div class="text-center">
            <p class="text-xs text-gray-500">End</p>
            <p class="text-sm font-semibold text-gray-900"><%= @advertisement.ends_at&.strftime("%b %d, %Y") || "No end date" %></p>
            <p class="text-xs text-gray-400"><%= @advertisement.ends_at&.strftime("%I:%M %p") %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%# Sidebar Details %>
  <div class="space-y-6">
    <%# Ad Info %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Details</h3>
      <dl class="space-y-4">
        <div>
          <dt class="text-xs font-medium text-gray-500">Ad Type</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @advertisement.ad_type.titleize %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Placement</dt>
          <dd class="mt-1">
            <% placement_colors = { "top_banner" => "bg-blue-100 text-blue-800", "sidebar" => "bg-purple-100 text-purple-800", "in_feed" => "bg-teal-100 text-teal-800", "popup" => "bg-orange-100 text-orange-800" } %>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= placement_colors[@advertisement.placement] %>">
              <%= @advertisement.placement.titleize %>
            </span>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Position</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @advertisement.position %></dd>
        </div>
        <% if @advertisement.target_url.present? %>
          <div>
            <dt class="text-xs font-medium text-gray-500">Target URL</dt>
            <% safe_url = @advertisement.target_url.start_with?("http://", "https://") ? @advertisement.target_url : "#" %>
            <dd class="mt-1 text-sm text-primary-600 truncate"><%= link_to truncate(@advertisement.target_url, length: 40), safe_url, target: "_blank", rel: "noopener noreferrer" %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-xs font-medium text-gray-500">Slug</dt>
          <dd class="mt-1"><code class="bg-gray-100 px-2 py-0.5 rounded text-xs text-gray-600"><%= @advertisement.slug %></code></dd>
        </div>
      </dl>
    </div>

    <%# Options %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Options</h3>
      <div class="space-y-2">
        <div class="flex items-center">
          <% if @advertisement.open_in_new_tab? %>
            <svg class="h-5 w-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <% else %>
            <svg class="h-5 w-5 text-gray-300 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          <% end %>
          <span class="text-sm text-gray-700">Open in New Tab</span>
        </div>
        <div class="flex items-center">
          <% if @advertisement.responsive? %>
            <svg class="h-5 w-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <% else %>
            <svg class="h-5 w-5 text-gray-300 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          <% end %>
          <span class="text-sm text-gray-700">Responsive</span>
        </div>
      </div>
    </div>

    <%# Dates %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Dates</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-xs font-medium text-gray-500">Created</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @advertisement.created_at.strftime("%b %d, %Y at %I:%M %p") %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Updated</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @advertisement.updated_at.strftime("%b %d, %Y at %I:%M %p") %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
