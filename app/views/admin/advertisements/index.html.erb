<% content_for(:title, "Advertisements") %>

<%# Header %>
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Advertisements</h1>
  <%= link_to new_admin_advertisement_path, class: "inline-flex items-center rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700 transition-colors" do %>
    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    New Advertisement
  <% end %>
</div>

<%# Search + Placement Filter %>
<div class="mb-6 flex flex-col sm:flex-row gap-3">
  <%= form_tag admin_advertisements_path, method: :get, class: "flex-1 flex gap-3" do %>
    <% if params[:status].present? %>
      <input type="hidden" name="status" value="<%= params[:status] %>">
    <% end %>
    <div class="relative flex-1">
      <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
      <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search advertisements..."
        class="block w-full rounded-md border border-gray-300 bg-white py-2 pl-10 pr-3 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none">
    </div>
    <select name="placement" onchange="this.form.submit()"
      class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none">
      <option value="">All Placements</option>
      <option value="top_banner" <%= 'selected' if params[:placement] == 'top_banner' %>>Top Banner</option>
      <option value="sidebar" <%= 'selected' if params[:placement] == 'sidebar' %>>Sidebar</option>
      <option value="in_feed" <%= 'selected' if params[:placement] == 'in_feed' %>>In-Feed</option>
      <option value="popup" <%= 'selected' if params[:placement] == 'popup' %>>Popup</option>
    </select>
    <button type="submit" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm border border-gray-300 hover:bg-gray-50 transition-colors">
      Search
    </button>
    <% if params[:q].present? || params[:placement].present? %>
      <%= link_to admin_advertisements_path(status: params[:status]), class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm text-gray-500 border border-gray-300 hover:bg-gray-50 transition-colors" do %>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>
    <% end %>
  <% end %>
</div>

<%# Status Filter Tabs %>
<div class="mb-6 border-b border-gray-200">
  <nav class="flex space-x-8" aria-label="Advertisement status filters">
    <%= link_to "All", admin_advertisements_path(q: params[:q], placement: params[:placement]),
        class: "pb-3 px-1 text-sm font-medium border-b-2 transition-colors #{params[:status].blank? ? 'border-primary-600 text-primary-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
    <%= link_to "Active", admin_advertisements_path(status: :active, q: params[:q], placement: params[:placement]),
        class: "pb-3 px-1 text-sm font-medium border-b-2 transition-colors #{params[:status] == 'active' ? 'border-green-600 text-green-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
    <%= link_to "Draft", admin_advertisements_path(status: :draft, q: params[:q], placement: params[:placement]),
        class: "pb-3 px-1 text-sm font-medium border-b-2 transition-colors #{params[:status] == 'draft' ? 'border-gray-500 text-gray-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
    <%= link_to "Paused", admin_advertisements_path(status: :paused, q: params[:q], placement: params[:placement]),
        class: "pb-3 px-1 text-sm font-medium border-b-2 transition-colors #{params[:status] == 'paused' ? 'border-yellow-500 text-yellow-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
    <%= link_to "Expired", admin_advertisements_path(status: :expired, q: params[:q], placement: params[:placement]),
        class: "pb-3 px-1 text-sm font-medium border-b-2 transition-colors #{params[:status] == 'expired' ? 'border-red-500 text-red-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
  </nav>
</div>

<%# Advertisements Table %>
<div class="bg-white rounded-lg shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ad</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Placement</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Impressions</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Clicks</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">CTR</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @advertisements.each do |ad| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="flex items-center">
                <%# Thumbnail %>
                <div class="h-10 w-16 shrink-0 rounded overflow-hidden bg-gray-100 mr-3">
                  <% if ad.image? && ad.image.attached? %>
                    <%= image_tag ad.image, class: "h-full w-full object-cover" %>
                  <% else %>
                    <div class="flex h-full w-full items-center justify-center">
                      <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                      </svg>
                    </div>
                  <% end %>
                </div>
                <div>
                  <%= link_to admin_advertisement_path(ad), class: "text-sm font-medium text-gray-900 hover:text-primary-600" do %>
                    <%= truncate(ad.title, length: 40) %>
                  <% end %>
                  <p class="text-xs text-gray-500">
                    <%= ad.image? ? "Image" : "HTML" %>
                    <% if ad.position > 0 %>
                      &middot; Pos: <%= ad.position %>
                    <% end %>
                  </p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% placement_colors = { "top_banner" => "bg-blue-100 text-blue-800", "sidebar" => "bg-purple-100 text-purple-800", "in_feed" => "bg-teal-100 text-teal-800", "popup" => "bg-orange-100 text-orange-800" } %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= placement_colors[ad.placement] %>">
                <%= ad.placement.titleize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% case ad.status %>
              <% when "active" %>
                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                  <span class="mr-1 h-1.5 w-1.5 rounded-full bg-green-500"></span>
                  Active
                </span>
              <% when "draft" %>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">Draft</span>
              <% when "paused" %>
                <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">Paused</span>
              <% when "expired" %>
                <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800">Expired</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if ad.scheduled? %>
                <div class="text-xs">
                  <% if ad.starts_at.present? %><div><%= ad.starts_at.strftime("%b %d, %Y") %></div><% end %>
                  <% if ad.ends_at.present? %><div class="text-gray-400">to <%= ad.ends_at.strftime("%b %d, %Y") %></div><% end %>
                </div>
              <% else %>
                <span class="text-gray-400">Always</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900 font-medium">
              <%= number_with_delimiter(ad.impressions_count) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900 font-medium">
              <%= number_with_delimiter(ad.clicks_count) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <% ctr = ad.ctr %>
              <span class="<%= ctr > 2 ? 'text-green-600 font-semibold' : 'text-gray-500' %>"><%= ctr %>%</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <div class="flex items-center justify-end space-x-3">
                <%= link_to admin_advertisement_path(ad), class: "text-gray-400 hover:text-gray-600" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                <% end %>
                <%= link_to edit_admin_advertisement_path(ad), class: "text-primary-600 hover:text-primary-700" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>
                <%= button_to admin_advertisement_path(ad), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this advertisement?" }, class: "text-red-600 hover:text-red-700" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @advertisements.empty? %>
          <tr>
            <td colspan="8" class="px-6 py-12 text-center text-sm text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
              </svg>
              <% if params[:q].present? %>
                <p class="font-medium">No results for "<%= params[:q] %>"</p>
                <p class="mt-1"><%= link_to "Clear search", admin_advertisements_path(status: params[:status]), class: "text-primary-600 hover:text-primary-700 font-medium" %></p>
              <% else %>
                <p class="font-medium">No advertisements found</p>
                <p class="mt-1 text-gray-400">Get started by creating a new advertisement.</p>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <% if @pagy && @pagy.pages > 1 %>
    <div class="bg-white px-6 py-4 border-t border-gray-200">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
