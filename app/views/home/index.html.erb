<% content_for(:title, t('home.title')) %>

<%# Breaking News Ticker %>
<% if @breaking_news.any? %>
  <div class="bg-red-600" data-controller="news-ticker" data-news-ticker-speed-value="60"
       data-action="mouseenter->news-ticker#pause mouseleave->news-ticker#resume">
    <div class="mx-auto max-w-7xl px-4 py-2.5 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3">
        <span class="inline-flex shrink-0 items-center gap-1.5 rounded bg-white px-2.5 py-0.5 text-xs font-bold uppercase tracking-wide text-red-600 z-10">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-500 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-red-600"></span>
          </span>
          <%= t('home.breaking') %>
        </span>
        <div class="overflow-hidden min-w-0 flex-1">
          <div class="flex items-center gap-6 whitespace-nowrap will-change-transform" data-news-ticker-target="track">
            <% @breaking_news.each do |article| %>
              <%= link_to article.title, article_path(article),
                    class: "inline-block whitespace-nowrap text-sm font-medium text-white hover:text-red-100 transition" %>
              <span class="text-red-300">&bull;</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# Top Banner Ad %>
<%= render_ad(:top_banner) %>

<%# Hero / Featured Articles Section %>
<section class="bg-white py-8 lg:py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <% if @featured_articles.any? %>
      <div class="grid gap-6 lg:grid-cols-3 lg:gap-8">
        <%# Main featured article (takes 2 columns) %>
        <div class="lg:col-span-2">
          <%= render "shared/article_card", article: @featured_articles.first, size: :large %>
        </div>

        <%# Sidebar stack of featured articles %>
        <div class="flex flex-col gap-6">
          <% @featured_articles.drop(1).take(3).each do |article| %>
            <%= link_to article_path(article), class: "group flex flex-col overflow-hidden rounded-xl bg-gray-50 ring-1 ring-gray-900/5 transition hover:bg-gray-100" do %>
              <div class="relative aspect-video overflow-hidden">
                <% if article.featured_image.attached? %>
                  <%= image_tag article.featured_image, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105", alt: article.title %>
                <% else %>
                  <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-primary-50 to-primary-100">
                    <svg class="h-8 w-8 text-primary-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                    </svg>
                  </div>
                <% end %>
                <% if article.category.present? %>
                  <span class="absolute left-3 top-3 rounded-full bg-primary-600 px-2 py-0.5 text-xs font-semibold text-white">
                    <%= article.category.name %>
                  </span>
                <% end %>
              </div>
              <div class="p-4">
                <h3 class="font-serif text-base font-bold leading-snug text-gray-900 transition group-hover:text-primary-600">
                  <%= truncate(article.title, length: 65) %>
                </h3>
                <p class="mt-1.5 text-xs text-gray-500">
                  <%= time_ago_in_words(article.published_at) %> <%= t('shared.ago') %>
                </p>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<%# Latest News Section %>
<section class="py-10 lg:py-14">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 lg:text-3xl"><%= t('home.latest_news') %></h2>
        <p class="mt-1 text-sm text-gray-500"><%= t('home.latest_subtitle') %></p>
      </div>
      <%= link_to articles_path,
            class: "hidden items-center gap-1 rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm transition hover:bg-gray-50 sm:inline-flex" do %>
        <%= t('home.view_all') %>
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
        </svg>
      <% end %>
    </div>

    <% if @latest_articles.any? %>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% @latest_articles.each_with_index do |article, index| %>
          <%= render "shared/article_card", article: article, size: :medium %>
          <%# In-feed ad after 3rd article %>
          <% if index == 2 %>
            <%= render_ad(:in_feed) %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-xl border-2 border-dashed border-gray-300 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5" />
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-gray-900"><%= t('home.no_articles') %></h3>
        <p class="mt-1 text-sm text-gray-500"><%= t('home.no_articles_hint') %></p>
      </div>
    <% end %>

    <%# Mobile "View All" link %>
    <div class="mt-8 text-center sm:hidden">
      <%= link_to t('home.view_all_articles'), articles_path,
            class: "inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700" %>
    </div>
  </div>
</section>

<%# Categories Row %>
<% if @categories.any? %>
  <section class="border-y border-gray-200 bg-white py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-xl font-bold tracking-tight text-gray-900"><%= t('home.browse_by_category') %></h2>
      <div class="flex flex-wrap gap-3">
        <% @categories.each do |category| %>
          <%= link_to category.name, category_path(category),
                class: "inline-flex items-center rounded-full border border-gray-200 bg-gray-50 px-5 py-2.5 text-sm font-medium text-gray-700 transition hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700" %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# Popular Articles + Tag Cloud Section %>
<section class="py-10 lg:py-14">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-3 lg:gap-12">
      <%# Popular Articles %>
      <div class="lg:col-span-2">
        <h2 class="mb-6 text-xl font-bold tracking-tight text-gray-900">
          <span class="inline-flex items-center gap-2">
            <svg class="h-5 w-5 text-orange-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 0 0-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 0 0-.613 3.58 2.64 2.64 0 0 1-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 0 0 5.05 6.05 6.981 6.981 0 0 0 3 11a7 7 0 1 0 11.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03ZM12.12 15.12A3 3 0 0 1 7 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0 1 13 13a2.99 2.99 0 0 1-.879 2.121Z" clip-rule="evenodd" />
            </svg>
            <%= t('home.most_popular') %>
          </span>
        </h2>
        <% if @popular_articles.any? %>
          <div class="divide-y divide-gray-100">
            <% @popular_articles.each_with_index do |article, index| %>
              <%= link_to article_path(article), class: "group flex items-start gap-4 py-4" do %>
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-100 text-sm font-bold text-gray-500 group-hover:bg-primary-100 group-hover:text-primary-600">
                  <%= index + 1 %>
                </span>
                <div class="min-w-0 flex-1">
                  <h3 class="text-base font-semibold leading-snug text-gray-900 transition group-hover:text-primary-600">
                    <%= article.title %>
                  </h3>
                  <div class="mt-1 flex items-center gap-2 text-xs text-gray-500">
                    <% if article.category.present? %>
                      <span class="text-primary-600"><%= article.category.name %></span>
                      <span>&middot;</span>
                    <% end %>
                    <span><%= t('shared.views', count: article.views_count) %></span>
                    <span>&middot;</span>
                    <time datetime="<%= article.published_at&.iso8601 %>">
                      <%= time_ago_in_words(article.published_at) %> <%= t('shared.ago') %>
                    </time>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Tag Cloud %>
      <div>
        <h2 class="mb-6 text-xl font-bold tracking-tight text-gray-900">
          <span class="inline-flex items-center gap-2">
            <svg class="h-5 w-5 text-primary-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.5 3A2.5 2.5 0 0 0 3 5.5v2.879a2.5 2.5 0 0 0 .732 1.767l6.5 6.5a2.5 2.5 0 0 0 3.536 0l2.878-2.878a2.5 2.5 0 0 0 0-3.536l-6.5-6.5A2.5 2.5 0 0 0 8.38 3H5.5ZM6 7a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
            </svg>
            <%= t('home.popular_tags') %>
          </span>
        </h2>
        <% if @popular_tags.any? %>
          <div class="flex flex-wrap gap-2">
            <% @popular_tags.each do |tag| %>
              <%= link_to tag_path(tag), class: "inline-flex items-center gap-1 rounded-full border border-gray-200 bg-white px-3.5 py-1.5 text-sm text-gray-700 transition hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700" do %>
                <span>#</span>
                <span><%= tag.name %></span>
                <span class="ml-0.5 text-xs text-gray-400">(<%= tag.articles_count %>)</span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
